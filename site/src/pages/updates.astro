---
import Layout from '../layouts/Layout.astro';
import { getAnnouncements } from '../lib/data';

export const prerender = true;

const data = getAnnouncements();
const entries = data?.entries ?? [];

// タイプ別のラベルとスタイル
function typeLabel(type: string) {
  return type === 'announcement' ? 'お知らせ' : '更新';
}

function typeStyle(type: string) {
  return type === 'announcement'
    ? 'bg-blue-100 text-blue-800'
    : 'bg-gray-100 text-gray-600';
}
---

<Layout title="更新情報 - Kiryu Public Log" description="Kiryu Public Log の更新情報・お知らせ一覧" path="/updates">
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-2xl font-bold text-gray-900">更新情報</h1>
    <p class="mt-2 text-sm text-gray-500">サイトの更新やデータ修正などのお知らせをまとめています。</p>

    {entries.length === 0 ? (
      <p class="mt-8 text-sm text-gray-400">更新情報はまだありません。</p>
    ) : (
      <div class="mt-8 space-y-4">
        {entries.map((entry) => (
          <div class={`rounded-lg border bg-white px-5 py-4 ${entry.featured ? 'border-blue-200' : 'border-gray-200'}`}>
            <div class="flex items-center gap-3">
              <span class="shrink-0 text-sm text-gray-400">{entry.date}</span>
              <span class={`shrink-0 rounded px-1.5 py-0.5 text-xs font-medium ${typeStyle(entry.type)}`}>
                {typeLabel(entry.type)}
              </span>
              {entry.featured && (
                <span class="shrink-0 rounded px-1.5 py-0.5 text-xs font-medium bg-amber-100 text-amber-800">注目</span>
              )}
            </div>
            <p class="mt-2 font-medium text-gray-900">{entry.title}</p>
            <p class="mt-1 text-sm text-gray-600">{entry.content}</p>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
