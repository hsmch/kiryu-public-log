---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const SITE_URL = 'https://kiryu.co';

const {
  title = 'Kiryu Public Log',
  description = '桐生市の市政・議会の公開情報をわかりやすく整理してお届けするアーカイブサイト',
  path = '',
} = Astro.props;

const canonicalUrl = `${SITE_URL}${path}`;
---

<!doctype html>
<html lang="ja" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Kiryu Public Log" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Kiryu Public Log" href="/rss.xml" />

    <!-- Page transitions -->
    <ClientRouter />
    <script is:inline>document.documentElement.classList.remove('no-js');</script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <header class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-4xl px-4 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight text-gray-900 no-underline">
          Kiryu Public Log
        </a>
        <nav class="hidden md:flex gap-4 text-sm">
          <a href="/council" class="nav-link text-gray-600 hover:text-gray-900">議員一覧</a>
          <a href="/sessions" class="nav-link text-gray-600 hover:text-gray-900">議案・採決</a>
          <a href="/analysis" class="nav-link text-gray-600 hover:text-gray-900">投票分析</a>
          <a href="/finance" class="nav-link text-gray-600 hover:text-gray-900">まちの数字</a>
          <a href="/topics" class="nav-link text-gray-600 hover:text-gray-900">テーマ別</a>
          <a href="/search" class="nav-link text-gray-600 hover:text-gray-900">検索</a>
          <a href="/guide" class="nav-link text-gray-600 hover:text-gray-900">ガイド</a>
          <a href="/about" class="nav-link text-gray-600 hover:text-gray-900">about</a>
        </nav>
        <button
          id="menu-toggle"
          class="md:hidden p-2 -mr-2 text-gray-600 hover:text-gray-900"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="メニューを開く"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav id="mobile-menu" class="mobile-menu-enter md:hidden border-t border-gray-100" inert>
        <div class="mx-auto max-w-4xl px-4 py-3 flex flex-col gap-1 text-sm">
          <a href="/council" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">議員一覧</span>
            <span class="block text-xs text-gray-400">桐生市議会22名の活動記録</span>
          </a>
          <a href="/sessions" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">議案・採決</span>
            <span class="block text-xs text-gray-400">定例会ごとの議案と採決結果</span>
          </a>
          <a href="/analysis" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">投票分析</span>
            <span class="block text-xs text-gray-400">議員間の投票一致率・会派結束度</span>
          </a>
          <a href="/finance" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">まちの数字</span>
            <span class="block text-xs text-gray-400">人口・財政・予算データ</span>
          </a>
          <a href="/topics" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">テーマ別</span>
            <span class="block text-xs text-gray-400">議案・質問をテーマで横断整理</span>
          </a>
          <a href="/search" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">検索</span>
            <span class="block text-xs text-gray-400">サイト内全文検索</span>
          </a>
          <a href="/guide" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">ガイド</span>
            <span class="block text-xs text-gray-400">議会の仕組み・用語解説</span>
          </a>
          <a href="/about" class="text-gray-600 hover:text-gray-900 py-2">
            <span class="font-medium">about</span>
            <span class="block text-xs text-gray-400">このサイトについて</span>
          </a>
        </div>
      </nav>
    </header>
    <script>
      function initMobileMenu() {
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (!toggle || !menu) return;
        // Reset state after View Transition swap
        menu.classList.remove('is-open');
        menu.setAttribute('inert', '');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'メニューを開く');
        // Reset icon state
        const iconOpen = toggle.querySelector('#menu-icon-open');
        const iconClose = toggle.querySelector('#menu-icon-close');
        if (iconOpen) iconOpen.classList.remove('hidden');
        if (iconClose) iconClose.classList.add('hidden');
        // Use clone to avoid duplicate listeners
        const newToggle = toggle.cloneNode(true) as HTMLElement;
        toggle.replaceWith(newToggle);
        // Re-query icons from the cloned element
        const newIconOpen = newToggle.querySelector('#menu-icon-open');
        const newIconClose = newToggle.querySelector('#menu-icon-close');
        newToggle.addEventListener('click', () => {
          const expanded = newToggle.getAttribute('aria-expanded') === 'true';
          const isOpen = !expanded;
          newToggle.setAttribute('aria-expanded', String(isOpen));
          newToggle.setAttribute('aria-label', isOpen ? 'メニューを閉じる' : 'メニューを開く');
          menu.classList.toggle('is-open');
          if (isOpen) {
            menu.removeAttribute('inert');
          } else {
            menu.setAttribute('inert', '');
          }
          newIconOpen?.classList.toggle('hidden');
          newIconClose?.classList.toggle('hidden');
        });
      }
      document.addEventListener('astro:page-load', initMobileMenu);
    </script>

    <main data-pagefind-body transition:animate="fade">
      <slot />
    </main>

    <script>
      let scrollRevealObserver: IntersectionObserver | null = null;
      function initScrollReveal() {
        scrollRevealObserver?.disconnect();
        scrollRevealObserver = null;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.querySelectorAll('.scroll-reveal, .stagger-children').forEach((el) => {
            el.classList.add('is-visible');
          });
          return;
        }
        scrollRevealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                scrollRevealObserver?.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.scroll-reveal, .stagger-children').forEach((el) => {
          scrollRevealObserver!.observe(el);
        });
      }
      document.addEventListener('astro:page-load', initScrollReveal);
    </script>

    <footer class="mt-auto border-t border-gray-200 bg-white">
      <div class="mx-auto max-w-4xl px-4 py-6 text-center text-sm text-gray-500">
        <p>
          このサイトは桐生市の公開情報を整理・提供する非公式のアーカイブです。
          桐生市および桐生市議会とは一切関係ありません。
        </p>
        <p class="mt-2">
          情報の正確性については
          <a
            href="https://www.city.kiryu.lg.jp/shigikai/index.html"
            class="text-blue-600 underline hover:text-blue-800"
            target="_blank"
            rel="noopener noreferrer"
          >
            桐生市議会公式サイト
          </a>
          をご確認ください。
        </p>
        <p class="mt-2 flex justify-center gap-4">
          <a href="/about" class="text-blue-600 underline hover:text-blue-800">このサイトについて</a>
          <a href="/guide" class="text-blue-600 underline hover:text-blue-800">議会の仕組みガイド</a>
          <a href="/participate" class="text-blue-600 underline hover:text-blue-800">市政に関わるには</a>
          <a href="https://github.com/hsmch/kiryu-public-log" class="text-blue-600 underline hover:text-blue-800" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="/rss.xml" class="text-blue-600 underline hover:text-blue-800">RSS</a>
        </p>
      </div>
    </footer>
  </body>
</html>
